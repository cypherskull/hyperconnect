# ================================
# Local Development Environment
# ================================

# Backend API
NODE_ENV=development
PORT=3001

# Database (local Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hyperconnect?schema=public

# JWT Authentication
JWT_SECRET=local-dev-secret-change-in-production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ================================
# AWS Configuration (Production)
# ================================
# Uncomment and configure for AWS deployment

# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
# S3_BUCKET_NAME=hyperconnect-uploads

# Production Database
# DATABASE_URL=postgresql://user:password@your-rds-endpoint:5432/hyperconnect?schema=public
