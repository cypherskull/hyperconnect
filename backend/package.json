{
    "name": "hyperconnect-backend",
    "version": "1.0.0",
    "description": "Backend API for HyperConnect platform",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "db:migrate": "prisma migrate dev",
        "db:push": "prisma db push",
        "db:seed": "ts-node prisma/seed.ts",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@prisma/client": "^5.10.0",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.1",
        "express": "^4.18.2",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "multer-s3": "^3.0.1",
        "@aws-sdk/client-s3": "^3.513.0",
        "@aws-sdk/s3-request-presigner": "^3.513.0",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/multer": "^1.4.11",
        "@types/multer-s3": "^3.0.3",
        "@types/node": "^20.11.16",
        "prisma": "^5.10.0",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3",
        "@types/uuid": "^9.0.0"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}